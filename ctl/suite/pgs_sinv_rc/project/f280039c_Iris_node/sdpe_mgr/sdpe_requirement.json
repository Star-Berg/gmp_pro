  "option_macros": [
    {
      "group": "Control Mode",
      "macro": "BUILD_LEVEL",
      "enabled": true,
      "weak": false,
      "value": "(5)",
      "options_preset": "",
      "options": [
        "(1)",
        "(2)",
        "(3)",
        "(4)",
        "(5)"
      ],
      "description": "Single-phase converter commissioning build level, aligned with the simulation controller branches.\nBUILD_LEVEL 1: open-loop H-bridge modulation for resistive-load validation.\nBUILD_LEVEL 2: sinusoidal current command for resistive-load current-loop validation.\nBUILD_LEVEL 3: grid current loop with signed P/Q command.\nBUILD_LEVEL 4: measured active-power outer loop feeding the grid current loop.\nBUILD_LEVEL 5: rectifier DC-bus voltage loop with PF-derived Q command."
