      "requirements": [
        "active_power_ref",
        "reactive_power_ref",
        "level2_id",
        "level2_iq",
        "level3_id",
        "level3_iq",
        "level4_id",
        "level4_iq"
      ]
    },
    {
      "name": "BUILD_LEVEL 6 Off-Grid Voltage Control",
      "requirements": [
        "level6_line_voltage_rms",
