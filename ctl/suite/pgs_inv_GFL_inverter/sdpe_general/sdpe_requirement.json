{
  "id": "pgs_inv_gfl_common",
  "macro_prefix": "PGS_INV_GFL_COMMON",
  "display_name": "PGS Grid-Following Inverter Common Settings",
  "description": "Platform-independent control contract shared by all pgs_inv_GFL_inverter projects. Hardware timing, sensing, board resources and BUILD_LEVEL selection remain in each platform requirement.",
  "suite": "pgs_inv_GFL_inverter",
  "version": "1.0.0",
  "updated_at": "2026-07-23",
  "output_header": "sdpe_pgs_inv_gfl_common_settings.h",
  "hardware": [],
  "code_sections": {
    "after_extern_open": "/* Platform-independent GFL controller settings. */",
    "before_footer": "/* Accept the historical PIL spelling while new projects use the canonical switch. */\n#if defined ENBALE_GMP_DL_PIL_SIM && !defined ENABLE_GMP_DL_PIL_SIM\n#define ENABLE_GMP_DL_PIL_SIM\n#endif"
  },
  "feature_macros": [
    {
      "group": "Control Algorithm",
      "macro": "_USE_DEBUG_DISCRETE_PID",
      "enabled": true,
      "weak": false,
      "value": "",
      "description": "Enable the existing discrete PID anti-saturation path."
    },
    {
      "group": "Control Algorithm",
      "macro": "USING_DSOGI_PLL",
      "enabled": false,
      "weak": false,
      "value": "",
      "description": "Use DSOGI PLL instead of the default SRF PLL."
    },
    {
      "group": "Control Algorithm",
      "macro": "USING_NPC_MODULATOR",
      "enabled": false,
      "weak": false,
      "value": "",
      "description": "Use the three-level NPC modulator instead of the two-level SPWM modulator."
    },
    {
      "group": "Runtime",
      "macro": "SPECIFY_ENABLE_ADC_CALIBRATE",
      "enabled": false,
      "weak": false,
      "value": "",
      "description": "Enable startup ADC offset calibration. Only enable while all calibrated power inputs are in a known zero state."
    },
    {
      "group": "Runtime",
      "macro": "ENABLE_GMP_DL_PIL_SIM",
      "enabled": false,
      "weak": false,
      "value": "",
      "description": "Enable processor-in-the-loop input/output handling."
    },
    {
      "group": "Runtime",
      "macro": "GMP_CTL_FM_CONFIG_ENABLE_DEBUG_INFO",
      "enabled": false,
      "weak": false,
      "value": "",
      "description": "Enable CiA402/GMP framework debug information."
    }
  ],
  "option_macros": [
    {
      "group": "Sampling",
      "macro": "GFL_CAPACITOR_CURRENT_CALCULATE_MODE",
      "enabled": true,
      "weak": false,
      "value": "(3)",
      "options_preset": "",
      "options": [
        "(1)",
        "(2)",
        "(3)"
      ],
      "description": "Capacitor-current source: direct measurement, current difference, or capacitor-voltage derivative."
    }
  ],
  "requirements": [
    {
      "role": "grid_voltage_pu",
      "macro": "GFL_GRID_VOLTAGE_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.33"
      },
      "description": "Nominal grid phase-voltage magnitude in controller per unit."
    },
    {
      "role": "pq_loop_frequency",
      "macro": "GFL_PQ_LOOP_FREQUENCY_HZ",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "1000.0"
      },
      "description": "P/Q outer-loop execution frequency in hertz."
    },
    {
      "role": "pq_loop_divider",
      "macro": "GFL_PQ_LOOP_DIVIDER",
      "enabled": true,
      "weak": false,
      "binding": {
        "literal": "((uint32_t)(CONTROLLER_FREQUENCY / GFL_PQ_LOOP_FREQUENCY_HZ))"
      },
      "description": "Current-ISR to P/Q-loop execution divider."
    },
    {
      "role": "pq_active_kp",
      "macro": "GFL_PQ_ACTIVE_KP",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.75"
      },
      "description": "Active-power loop proportional gain from P error PU to d-axis current PU."
    },
    {
      "role": "pq_active_ki",
      "macro": "GFL_PQ_ACTIVE_KI",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.001"
      },
      "description": "Active-power loop integral gain in inverse seconds."
    },
    {
      "role": "pq_reactive_kp",
      "macro": "GFL_PQ_REACTIVE_KP",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.75"
      },
      "description": "Reactive-power loop proportional gain from Q error PU to q-axis current PU."
    },
    {
      "role": "pq_reactive_ki",
      "macro": "GFL_PQ_REACTIVE_KI",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.001"
      },
      "description": "Reactive-power loop integral gain in inverse seconds."
    },
    {
      "role": "pq_current_limit",
      "macro": "GFL_PQ_CURRENT_LIMIT_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "1.0"
      },
      "description": "Circular magnitude limit applied to the d/q current reference produced by the P/Q loop."
    },
    {
      "role": "open_loop_vd",
      "macro": "GFL_OPEN_LOOP_VD_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.6"
      },
      "description": "BUILD_LEVEL 1 d-axis open-loop voltage command."
    },
    {
      "role": "open_loop_vq",
      "macro": "GFL_OPEN_LOOP_VQ_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.6"
      },
      "description": "BUILD_LEVEL 1 q-axis open-loop voltage command."
    },
    {
      "role": "pll_lock_epsilon",
      "macro": "CTRL_SPLL_EPSILON",
      "enabled": true,
      "weak": false,
      "binding": {
        "literal": "((float2ctrl(0.005)))"
      },
      "description": "PLL lock-error threshold in controller per unit."
    },
    {
      "role": "active_power_ref",
      "macro": "GFL_ACTIVE_POWER_REF_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.1"
      },
      "description": "Default active-power reference. Positive power exports energy to the grid."
    },
    {
      "role": "reactive_power_ref",
      "macro": "GFL_REACTIVE_POWER_REF_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.0"
      },
      "description": "Default reactive-power reference using Q = vq*id - vd*iq."
    },
    {
      "role": "level2_id",
      "macro": "GFL_CURRENT_LEVEL2_ID_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.1"
      },
      "description": "BUILD_LEVEL 2 d-axis current command."
    },
    {
      "role": "level2_iq",
      "macro": "GFL_CURRENT_LEVEL2_IQ_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.1"
      },
      "description": "BUILD_LEVEL 2 q-axis current command."
    },
    {
      "role": "level3_id",
      "macro": "GFL_CURRENT_LEVEL3_ID_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.1"
      },
      "description": "BUILD_LEVEL 3 grid-connected d-axis current command."
    },
    {
      "role": "level3_iq",
      "macro": "GFL_CURRENT_LEVEL3_IQ_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.0"
      },
      "description": "BUILD_LEVEL 3 grid-connected q-axis current command."
    },
    {
      "role": "level4_id",
      "macro": "GFL_CURRENT_LEVEL4_ID_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.6"
      },
      "description": "BUILD_LEVEL 4 d-axis current command."
    },
    {
      "role": "level4_iq",
      "macro": "GFL_CURRENT_LEVEL4_IQ_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.6"
      },
      "description": "BUILD_LEVEL 4 q-axis current command."
    },
    {
      "role": "level6_line_voltage_rms",
      "macro": "GFL_LEVEL6_OUTPUT_LINE_RMS_V",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "32.0"
      },
      "description": "BUILD_LEVEL 6 default line-to-line RMS voltage command in volts."
    },
    {
      "role": "level6_voltage_min_rms",
      "macro": "GFL_LEVEL6_VOLTAGE_MIN_RMS_V",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "24.0"
      },
      "description": "Minimum line-to-line RMS voltage accepted by the Level 6 runtime interface."
    },
    {
      "role": "level6_voltage_max_rms",
      "macro": "GFL_LEVEL6_VOLTAGE_MAX_RMS_V",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "36.0"
      },
      "description": "Maximum line-to-line RMS voltage accepted by the Level 6 runtime interface."
    },
    {
      "role": "level6_voltage_step_rms",
      "macro": "GFL_LEVEL6_VOLTAGE_STEP_RMS_V",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.5"
      },
      "description": "Line-to-line RMS voltage command resolution for Level 6."
    },
    {
      "role": "level6_frequency",
      "macro": "GFL_LEVEL6_OUTPUT_FREQUENCY_HZ",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "50.0"
      },
      "description": "BUILD_LEVEL 6 default stand-alone output frequency."
    },
    {
      "role": "level6_frequency_min",
      "macro": "GFL_LEVEL6_FREQUENCY_MIN_HZ",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "20.0"
      },
      "description": "Minimum Level 6 output-frequency command."
    },
    {
      "role": "level6_frequency_max",
      "macro": "GFL_LEVEL6_FREQUENCY_MAX_HZ",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "100.0"
      },
      "description": "Maximum Level 6 output-frequency command."
    },
    {
      "role": "level6_frequency_step",
      "macro": "GFL_LEVEL6_FREQUENCY_STEP_HZ",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "1.0"
      },
      "description": "Level 6 output-frequency command resolution."
    },
    {
      "role": "level6_voltage_slew",
      "macro": "GFL_LEVEL6_VOLTAGE_SLEW_V_PER_S",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "100.0"
      },
      "description": "Line-to-line RMS soft-start and command slew rate."
    },
    {
      "role": "level6_voltage_loop_bw",
      "macro": "GFL_LEVEL6_VOLTAGE_LOOP_BW_HZ",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "80.0"
      },
      "description": "Proportional design bandwidth for the Level 6 voltage QPR loop."
    },
    {
      "role": "level6_current_loop_bw",
      "macro": "GFL_LEVEL6_CURRENT_LOOP_BW_HZ",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "600.0"
      },
      "description": "Proportional design bandwidth for the Level 6 estimated-inductor-current QPR loop."
    },
    {
      "role": "level6_voltage_qpr_kr",
      "macro": "GFL_LEVEL6_VOLTAGE_QPR_KR",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "1.00"
      },
      "description": "Resonant gain from voltage error PU to estimated inductor-current reference PU."
    },
    {
      "role": "level6_current_qpr_kr",
      "macro": "GFL_LEVEL6_CURRENT_QPR_KR",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.80"
      },
      "description": "Resonant gain from estimated inductor-current error PU to SPWM modulation index."
    },
    {
      "role": "level6_qpr_bandwidth",
      "macro": "GFL_LEVEL6_QPR_BANDWIDTH_HZ",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "5.0"
      },
      "description": "Half-width of the Level 6 quasi-resonant terms around the commanded frequency."
    },
    {
      "role": "level6_current_limit",
      "macro": "GFL_LEVEL6_CURRENT_LIMIT_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.80"
      },
      "description": "Circular limit for the Level 6 estimated inductor-current reference."
    },
    {
      "role": "level6_modulation_limit",
      "macro": "GFL_LEVEL6_MODULATION_LIMIT_PU",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.95"
      },
      "description": "Circular SPWM modulation limit used by Level 6."
    },
    {
      "role": "level6_active_damping_resistance",
      "macro": "GFL_LEVEL6_ACTIVE_DAMPING_RESISTANCE_OHM",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "3.5"
      },
      "description": "Virtual resistance applied to estimated capacitor current for LC active damping."
    },
    {
      "role": "adc_calibrator_cutoff",
      "macro": "GFL_ADC_CALIBRATOR_FC_HZ",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "20.0"
      },
      "description": "ADC offset calibrator filter cutoff frequency."
    },
    {
      "role": "adc_calibrator_q",
      "macro": "GFL_ADC_CALIBRATOR_Q",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "0.707"
      },
      "description": "ADC offset calibrator second-order filter quality factor."
    },
    {
      "role": "cia402_enable_delay",
      "macro": "GFL_CIA402_OPERATION_ENABLE_DELAY_MS",
      "enabled": true,
      "weak": false,
      "binding": {
        "number": "100"
      },
      "description": "Minimum CiA402 delay before Operation Enabled."
    },
    {
      "role": "grid_frequency",
      "macro": "GFL_GRID_FREQUENCY_HZ",
      "enabled": true,
      "weak": false,
      "binding": {
        "float": "50.0"
      },
      "description": "Nominal grid frequency in hertz."
    }
  ],
  "requirement_groups": [
    {
      "name": "Control Loop Parameters",
      "requirements": [
