        "pq_loop_frequency",
        "pq_loop_divider",
        "pq_active_kp",
        "pq_active_ki",
        "pq_reactive_kp",
        "pq_reactive_ki",
        "pq_current_limit",
        "open_loop_vd",
        "open_loop_vq",
        "pll_lock_epsilon"
      ]
    },
    {
